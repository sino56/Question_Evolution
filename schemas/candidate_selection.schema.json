{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Selection",
  "type": "object",
  "additionalProperties": true,
  "required": ["selection_reason"],
  "properties": {
    "selected": {
      "type": "boolean"
    },
    "selected_candidate_id": {
      "type": "string"
    },
    "selected_operator": {
      "type": "string"
    },
    "selection_status": {
      "type": "string"
    },
    "selection_score": {
      "type": "number"
    },
    "difficulty_gain_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "difficulty_gain_label": {
      "type": ["string", "null"]
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selection_reason": {
      "type": "string"
    },
    "rejected_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["candidate_id", "reject_reason"],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "reject_reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
