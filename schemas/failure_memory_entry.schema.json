{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Failure Memory Entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "sample_id",
    "round",
    "sample_signature",
    "operator_used",
    "failure_type",
    "failure_reason"
  ],
  "properties": {
    "sample_id": {
      "type": ["string", "number"]
    },
    "round": {
      "type": "integer",
      "minimum": 0
    },
    "sample_signature": {
      "type": "object",
      "additionalProperties": true
    },
    "operator_used": {
      "type": "string"
    },
    "surface_form_family": {
      "type": "string"
    },
    "score_rate_before": {
      "type": ["number", "null"]
    },
    "score_rate_after": {
      "type": ["number", "null"]
    },
    "failure_type": {
      "type": "string"
    },
    "failure_reason": {
      "type": "string"
    },
    "avoid_note": {
      "type": "string"
    },
    "source_stage": {
      "type": "string"
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
